{
  "manifest_version": 3,
  "name": "Carrier Pigeon",
  "version": "1.0.0",
  "description": "Replaces UTM tracking parameters with hilariously implausible alternatives. Carrier pigeons, ouija boards, and ancient prophecies.",
  "permissions": [
    "declarativeNetRequest",
    "webNavigation",
    "storage"
  ],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Carrier Pigeon"
  }
}
